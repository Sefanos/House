COMPOSE_PROJECT_NAME=houseplan

APP_DOMAIN=app.example.com
SPACETIME_DOMAIN=spacetime.example.com
LIVEKIT_DOMAIN=livekit.example.com
TRAEFIK_ACME_EMAIL=[email protected]

NEXT_PUBLIC_SPACETIME_URL=wss://spacetime.example.com
NEXT_PUBLIC_SPACETIME_MODULE=houseplan
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.example.com
# Optional: required only if you want the GIF picker to call GIPHY.
NEXT_PUBLIC_GIPHY_API_KEY=

LIVEKIT_API_KEY=houseplan
LIVEKIT_API_SECRET=replace-with-a-long-random-secret

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=houseplan-uploads
R2_PUBLIC_URL=

SPACETIME_SERVER_URL=http://spacetimedb:3000
SPACETIME_MODULE_NAME=houseplan

WEB_IMAGE=ghcr.io/example/house_app-web:latest
SPACETIME_PUBLISHER_IMAGE=ghcr.io/example/house_app-spacetime-publisher:latest

GHCR_USERNAME=example
GHCR_TOKEN=ghp_xxx
